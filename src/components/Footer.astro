---
import type { Lang } from '../data/i18n';

export interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const currentYear = new Date().getFullYear();

const tagline: Record<Lang, string> = {
  en: 'Still amazed that proteins remember how to fold. Still trying to teach them new tricks.',
  es: 'Aún asombrado de que las proteínas recuerden cómo plegarse. Aún intentando enseñarles trucos nuevos.',
  ca: 'Encara sorprès que les proteïnes recordin com plegar-se. Encara intentant ensenyar-los trucs nous.',
};
---

<footer class="footer">
  <div class="footer__rule" aria-hidden="true"></div>
  <div class="container">
    <div class="footer__content">
      <div class="footer__left">
        <p class="footer__copyright">&copy; {currentYear} Ramon Roca Pinilla</p>
      </div>
      <div class="footer__right">
        <p class="footer__tagline">{tagline[lang]}</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-base, #0C1018);
    padding: 2.5rem 0;
  }

  .footer__rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 5%, var(--border-subtle) 25%, var(--border-subtle) 75%, transparent 95%);
    margin-bottom: 2.5rem;
  }

  .footer__content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .footer__copyright {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 0.875rem;
    color: var(--text-muted, #9BA5B3);
    margin: 0;
  }

  .footer__tagline {
    font-family: var(--font-display, 'Source Serif 4', serif);
    font-size: 0.9375rem;
    color: var(--text-secondary, #B8BFC9);
    font-style: italic;
    margin: 0;
    text-align: right;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.6s var(--ease-out-expo, cubic-bezier(0.25,1,0.5,1)),
                transform 0.6s var(--ease-out-expo, cubic-bezier(0.25,1,0.5,1));
  }
  .footer.is-visible .footer__tagline {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .footer__content {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }

    .footer__tagline {
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__tagline {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const footer = document.querySelector('.footer');
  if (footer && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    obs.observe(footer);
  } else if (footer) {
    footer.classList.add('is-visible');
  }
</script>
