---
import type { Lang } from '../../data/i18n';
import { translations } from '../../data/i18n';
import { writing } from '../../data/writing';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const v3 = (translations[lang] as any).v3;
const contactT = translations[lang].contact;

// Group by year (descending)
const years = [...new Set(writing.map((w) => w.year))].sort((a, b) => b.localeCompare(a));
---

<section id="writing" class="section v3-writing" aria-label={v3.writingHeading}>
  <div class="container">
    <h2 class="v3-writing__heading">{v3.writingHeading}</h2>

    {years.map((year) => (
      <div class="v3-writing__year-group">
        <h3 class="v3-writing__year">{year}</h3>
        <div class="v3-writing__list">
          {writing
            .filter((w) => w.year === year)
            .map((entry) => (
              <article class="v3-writing__entry">
                <div class="v3-writing__entry-header">
                  <h4 class="v3-writing__entry-title">
                    <a
                      href={`https://doi.org/${entry.doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="v3-writing__entry-link"
                    >
                      {entry.title[lang]}
                    </a>
                  </h4>
                  <span class="v3-writing__entry-journal">{entry.journal}</span>
                </div>
                <p class="v3-writing__entry-summary">{entry.summary[lang]}</p>
              </article>
            ))}
        </div>
      </div>
    ))}

    <div class="v3-writing__scholar">
      <a
        href="https://scholar.google.com/citations?user=YOUR_ID"
        target="_blank"
        rel="noopener noreferrer"
        class="v3-writing__scholar-link"
      >
        {contactT.viewAll} &rarr;
      </a>
    </div>
  </div>
</section>

<style>
  .v3-writing {
    background: var(--da-bg-deep, #030507);
  }

  .v3-writing__heading {
    font-family: var(--da-font-display, serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 200;
    color: var(--da-text-primary, #F0F2F5);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .v3-writing__year-group {
    margin-bottom: 2.5rem;
  }

  .v3-writing__year {
    font-family: var(--da-font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--da-accent-gold, #D4A84B);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--da-border, rgba(255,255,255,0.06));
  }

  .v3-writing__list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .v3-writing__entry {
    padding-left: 1rem;
    border-left: 2px solid var(--da-border, rgba(255,255,255,0.06));
    transition: border-color 0.3s ease;
  }

  .v3-writing__entry:hover {
    border-left-color: var(--da-accent-gold, #D4A84B);
  }

  .v3-writing__entry-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.375rem;
  }

  .v3-writing__entry-title {
    font-family: var(--da-font-display, serif);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--da-text-primary, #F0F2F5);
    margin: 0;
    line-height: 1.4;
  }

  .v3-writing__entry-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .v3-writing__entry-link:hover {
    color: var(--da-accent-gold, #D4A84B);
  }

  .v3-writing__entry-link:focus-visible {
    outline: 2px solid var(--da-accent-gold, #D4A84B);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .v3-writing__entry-journal {
    font-family: var(--da-font-mono, monospace);
    font-size: 0.6875rem;
    color: var(--da-text-muted, #7A8494);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .v3-writing__entry-summary {
    font-family: var(--da-font-body, sans-serif);
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--da-text-secondary, #B8BFC9);
    margin: 0;
  }

  .v3-writing__scholar {
    margin-top: 2rem;
  }

  .v3-writing__scholar-link {
    font-family: var(--da-font-mono, monospace);
    font-size: 0.8125rem;
    color: var(--da-accent-gold, #D4A84B);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.2s ease;
  }

  .v3-writing__scholar-link:hover {
    opacity: 0.8;
  }

  .v3-writing__scholar-link:focus-visible {
    outline: 2px solid var(--da-accent-gold, #D4A84B);
    outline-offset: 4px;
  }

  @media (max-width: 768px) {
    .v3-writing__entry-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
