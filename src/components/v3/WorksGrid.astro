---
import type { Lang } from '../../data/i18n';
import { translations } from '../../data/i18n';
import { works } from '../../data/works';
import WorkCard from './WorkCard.astro';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const v3 = (translations[lang] as any).v3;
---

<section id="works" class="section v3-works" aria-label={v3.worksHeading}>
  <div class="container">
    <h2 class="v3-works__heading">{v3.worksHeading}</h2>
    <div class="v3-works__grid">
      {works.map((work, i) => (
        <WorkCard work={work} lang={lang} index={i} />
      ))}
    </div>
  </div>
</section>

<style>
  .v3-works {
    background: var(--da-bg-deep, #030507);
  }

  .v3-works__heading {
    font-family: var(--da-font-display, serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 200;
    color: var(--da-text-primary, #F0F2F5);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .v3-works__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .v3-works__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>

<script>
  function initWorksGrid() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cards = document.querySelectorAll('[data-v3-stagger]');
    if (!cards.length) return;

    // Set initial state
    cards.forEach((card) => {
      (card as HTMLElement).style.opacity = '0';
      (card as HTMLElement).style.transform = 'translateY(24px)';
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.getAttribute('data-v3-stagger') || '0', 10) * 100;
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s cubic-bezier(0.25,1,0.5,1), transform 0.6s cubic-bezier(0.25,1,0.5,1)';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1 }
    );

    cards.forEach((card) => observer.observe(card));
  }

  document.addEventListener('DOMContentLoaded', initWorksGrid);
  document.addEventListener('astro:page-load', initWorksGrid);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initWorksGrid();
  }
</script>
