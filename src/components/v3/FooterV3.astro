---
import type { Lang } from '../../data/i18n';
import { translations } from '../../data/i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const v3 = (translations[lang] as any).v3;
const currentYear = new Date().getFullYear();
---

<footer class="v3-footer">
  <div class="v3-footer__rule" aria-hidden="true"></div>
  <div class="container">
    <div class="v3-footer__content">
      <p class="v3-footer__copy">&copy; {currentYear} Ramon Roca Pinilla</p>
      <p class="v3-footer__tagline">{v3.footerTagline}</p>
    </div>
  </div>
</footer>

<style>
  .v3-footer {
    background: var(--da-bg-deep, #030507);
    padding: 2rem 0;
  }

  .v3-footer__rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 5%, var(--da-border, rgba(255,255,255,0.06)) 30%, var(--da-border) 70%, transparent 95%);
    margin-bottom: 2rem;
  }

  .v3-footer__content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .v3-footer__copy {
    font-family: var(--da-font-body, sans-serif);
    font-size: 0.8125rem;
    color: var(--da-text-muted, #7A8494);
    margin: 0;
  }

  .v3-footer__tagline {
    font-family: var(--da-font-display, serif);
    font-size: 0.875rem;
    color: var(--da-text-secondary, #B8BFC9);
    font-style: italic;
    margin: 0;
    text-align: right;
  }

  @media (max-width: 768px) {
    .v3-footer__content {
      flex-direction: column;
      text-align: center;
      gap: 0.5rem;
    }

    .v3-footer__tagline {
      text-align: center;
    }
  }
</style>
