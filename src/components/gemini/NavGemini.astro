---
import type { Lang } from '../../data/i18n';
import { translations } from '../../data/i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const t = translations[lang] || translations.en;

const navLinks = [
  { href: '#works',   label: t.nav.works },
  { href: '#about',   label: t.nav.about },
  { href: '#writing', label: t.nav.writing },
  { href: '#contact', label: t.nav.contact },
];

const langs: Lang[] = ['en', 'es', 'ca'];
---

<header class="gn-header" role="banner">
  <a href="#top" class="gn-logo" aria-label="Back to top">RAMON ROCA PINILLA</a>

  <!-- Desktop nav -->
  <div class="gn-right">
    <nav class="gn-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="gn-link">{link.label}</a>
      ))}
    </nav>

    <div class="gn-divider" aria-hidden="true"></div>

    <div class="gn-lang" role="group" aria-label="Language switcher">
      {langs.map((l) => (
        <a
          href={`${base}${l}/`}
          class:list={['gn-lang-btn', { 'gn-lang-btn--active': l === lang }]}
          aria-current={l === lang ? 'page' : undefined}
          hreflang={l}
        >
          {l.toUpperCase()}
        </a>
      ))}
    </div>
  </div>

  <!-- Mobile hamburger -->
  <button
    class="gn-hamburger"
    id="gn-hamburger"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="gn-mobile-overlay"
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="3" y1="6"  x2="21" y2="6"  stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="3" y1="12" x2="21" y2="12" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="3" y1="18" x2="21" y2="18" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</header>

<!-- Mobile overlay -->
<div
  class="gn-overlay"
  id="gn-mobile-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  hidden
>
  <button
    class="gn-overlay-close"
    id="gn-overlay-close"
    aria-label="Close menu"
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="4" y1="4" x2="20" y2="20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="20" y1="4" x2="4" y2="20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <nav class="gn-overlay-nav" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a href={link.href} class="gn-overlay-link">{link.label}</a>
    ))}
  </nav>

  <div class="gn-overlay-lang" role="group" aria-label="Language switcher">
    {langs.map((l) => (
      <a
        href={`${base}${l}/`}
        class:list={['gn-lang-btn', 'gn-overlay-lang-btn', { 'gn-lang-btn--active': l === lang }]}
        aria-current={l === lang ? 'page' : undefined}
        hreflang={l}
      >
        {l.toUpperCase()}
      </a>
    ))}
  </div>
</div>

<style>
  /* ── Header ─────────────────────────────────────────────── */
  .gn-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2.5rem;
    mix-blend-mode: difference;
    /* No background, no blur, no border — blend mode handles readability */
  }

  /* ── Logo ────────────────────────────────────────────────── */
  .gn-logo {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: white;
    text-decoration: none;
  }

  .gn-logo:hover {
    opacity: 0.85;
  }

  /* ── Desktop right cluster ───────────────────────────────── */
  .gn-right {
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* ── Desktop nav links ───────────────────────────────────── */
  .gn-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .gn-link {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--gm-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .gn-link:hover {
    color: white;
  }

  .gn-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ── Divider between nav and lang switcher ───────────────── */
  .gn-divider {
    width: 1px;
    height: 1rem;
    background: rgba(255, 255, 255, 0.2);
    margin: 0 1rem;
    flex-shrink: 0;
  }

  /* ── Language switcher pills ─────────────────────────────── */
  .gn-lang {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .gn-lang-btn {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    color: var(--gm-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .gn-lang-btn:hover {
    color: white;
  }

  .gn-lang-btn--active {
    color: white;
    background: rgba(255, 255, 255, 0.15);
  }

  .gn-lang-btn:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 2px;
    border-radius: 9999px;
  }

  /* ── Mobile hamburger ────────────────────────────────────── */
  .gn-hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
  }

  .gn-hamburger:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ── Mobile overlay ──────────────────────────────────────── */
  .gn-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.98);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .gn-overlay[hidden] {
    display: none;
  }

  /* Close button */
  .gn-overlay-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gn-overlay-close:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* Mobile nav links */
  .gn-overlay-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .gn-overlay-link {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .gn-overlay-link:hover {
    opacity: 0.7;
  }

  .gn-overlay-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 6px;
    border-radius: 2px;
  }

  /* Mobile lang row */
  .gn-overlay-lang {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .gn-overlay-lang-btn {
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
  }

  /* ── Responsive: show hamburger, hide desktop nav ────────── */
  @media (max-width: 767px) {
    .gn-right {
      display: none;
    }

    .gn-hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('gn-hamburger') as HTMLButtonElement | null;
  const overlay   = document.getElementById('gn-mobile-overlay') as HTMLElement | null;
  const closeBtn  = document.getElementById('gn-overlay-close') as HTMLButtonElement | null;

  function openMenu(): void {
    if (!overlay || !hamburger) return;
    overlay.hidden = false;
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Close menu');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeMenu(): void {
    if (!overlay || !hamburger) return;
    overlay.hidden = true;
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Open menu');
    document.body.style.overflow = '';
    hamburger.focus();
  }

  hamburger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape key
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay && !overlay.hidden) {
      closeMenu();
    }
  });

  // Close when a mobile nav link is tapped (smooth scroll to section)
  overlay?.querySelectorAll<HTMLAnchorElement>('.gn-overlay-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
