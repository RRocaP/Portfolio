---
import type { Lang } from '../../data/i18n';
import { translations, geminiTimeline } from '../../data/i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
const gm = (translations[lang] as any).gemini;
const timeline = geminiTimeline[lang];
---

<section id="about">
  <div class="inner">
    <!-- Section header -->
    <div data-gm-reveal class="section-header">
      <h2 class="section-label">{gm.sectionAbout}</h2>
      <div class="divider"></div>
    </div>

    <!-- Two-column grid -->
    <div class="grid">

      <!-- Left column: bio + competencies -->
      <div data-gm-slide="left" class="col-left">
        <h3 class="about-title">{gm.aboutTitle}</h3>

        {gm.aboutBio.map((para: string) => (
          <p class="bio-para">{para}</p>
        ))}

        <!-- Competencies card -->
        <div class="competencies-card">
          <h4 class="competencies-heading">{gm.competenciesTitle}</h4>
          <ul class="competencies-grid">
            {gm.competencies.map((item: string) => (
              <li class="competency-item">
                <span class="dot"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Right column: timeline -->
      <div data-gm-slide="right" class="col-right">
        <div class="timeline-container">
          <div class="timeline-line"></div>
          <div class="timeline-entries">
            {timeline.map((entry) => (
              <div class="timeline-entry">
                <div class="timeline-dot"></div>
                <span class="timeline-year">{entry.year}</span>
                <h4 class="timeline-role">{entry.role}</h4>
                <span class="timeline-company">{entry.company}</span>
                <p class="timeline-desc">{entry.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  section#about {
    padding: 8rem 1.5rem;
    background: var(--gm-bg-section);
  }

  .inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  /* Section header */
  .section-header {
    margin-bottom: 4rem;
  }

  .section-label {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gm-accent-blue);
    margin-bottom: 1rem;
  }

  .divider {
    height: 1px;
    width: 100%;
    background: var(--border-light);
  }

  /* Two-column grid */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (max-width: 480px) {
    section#about {
      padding: 6rem 1rem;
    }
  }

  @media (min-width: 1024px) {
    section#about {
      padding: 8rem 3rem;
    }

    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Left column */
  .about-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: white;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
  }

  .bio-para {
    color: var(--gm-text-secondary);
    font-weight: 300;
    line-height: 1.625;
    margin-bottom: 1.5rem;
  }

  /* Competencies card */
  .competencies-card {
    margin-top: 3rem;
    padding: 1.5rem;
    border: 1px solid var(--border-light);
    background: var(--border);
    border-radius: 2px;
    backdrop-filter: blur(4px);
  }

  .competencies-heading {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    margin-bottom: 1rem;
  }

  .competencies-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .competency-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--gm-text-secondary);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gm-accent-blue);
    flex-shrink: 0;
  }

  /* Right column — timeline */
  .timeline-container {
    position: relative;
  }

  .timeline-line {
    position: absolute;
    left: 0;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: var(--border-light);
  }

  .timeline-entries {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .timeline-entry {
    position: relative;
    padding-left: 2rem;
  }

  .timeline-dot {
    position: absolute;
    left: -4px;
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gm-accent-teal);
    box-shadow: 0 0 10px rgba(66, 120, 114, 0.8);
  }

  .timeline-year {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--gm-accent-teal);
    display: block;
    margin-bottom: 0.25rem;
  }

  .timeline-role {
    font-size: 1.125rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.125rem;
  }

  .timeline-company {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gm-text-secondary);
    display: block;
    margin-bottom: 0.75rem;
  }

  .timeline-desc {
    font-size: 0.875rem;
    color: var(--gm-text-muted);
    font-weight: 300;
  }
</style>
