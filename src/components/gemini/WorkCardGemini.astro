---
import type { Lang } from '../../data/i18n';

interface Props {
  lang: Lang;
  yearRange: string;
  title: string;
  blurb: string;
  tags: string[];
  index: number;
}

const { lang, yearRange, title, blurb, tags, index } = Astro.props;
---

<article data-gm-reveal style={`transition-delay: ${index * 0.1}s`} class="work-card">
  <div class="year-badge">{yearRange}</div>
  <h3 class="card-title">{title}</h3>
  <p class="card-blurb">{blurb}</p>
  <div class="tag-row">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
</article>

<style>
  .work-card {
    border: 1px solid var(--border);
    background: var(--border);
    padding: 2rem;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    height: 100%;
    cursor: pointer;
    transition: background-color 0.5s;
  }

  .work-card:hover {
    background: var(--border-light);
  }

  .work-card:focus-visible {
    outline: 2px solid rgba(71, 97, 140, 0.6);
    outline-offset: 2px;
  }

  .work-card:hover .card-title {
    color: var(--gm-text-muted);
  }

  .year-badge {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    color: var(--gm-accent-teal);
    border: 1px solid rgba(66, 120, 114, 0.3);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gm-text-primary);
    letter-spacing: -0.025em;
    line-height: 1.375;
    margin-bottom: 1rem;
    transition: color 0.3s;
  }

  .card-blurb {
    font-size: 0.875rem;
    color: var(--gm-text-secondary);
    font-weight: 300;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    background: rgba(0, 0, 0, 0.4);
    color: var(--gm-text-secondary);
    border-radius: 2px;
  }
</style>
